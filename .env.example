# OpenRouter API Key (required)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database path (default: ./data/meetings.db)
DATABASE_PATH=./data/meetings.db

# Embedding model (default: openai/text-embedding-3-small)
EMBEDDING_MODEL=openai/text-embedding-3-small

# Chat model for summarization and RAG (default: anthropic/claude-sonnet-4-20250514)
# Other options: openai/gpt-4o, google/gemini-2.5-pro-preview-03-25, etc.
CHAT_MODEL=anthropic/claude-sonnet-4-20250514

# Max meetings to include in RAG context (default: 5)
MAX_CONTEXT_MEETINGS=5

# Authentication (optional) — if any are missing, auth is disabled
# MCP_USERNAME=admin
# MCP_PASSWORD=changeme
# JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
